    {
      "parameters": {
        "jsCode": "const text = ($json.message || \"\").toLowerCase();\n\nlet intent = \"general\";\n\nif (text.includes(\"demo\")) {\n  intent = \"demo\";\n}\nelse if (\n  text.includes(\"price\") ||\n  text.includes(\"pricing\") ||\n  text.includes(\"cost\")\n) {\n  intent = \"pricing\";\n}\nelse if (\n  text.includes(\"automation\") ||\n  text.includes(\"automate\") ||\n  text.includes(\"automated\")\n) {\n  intent = \"automation\";\n}\nelse if (\n  text.includes(\"whatsapp\") ||\n  text.includes(\" wa \")\n) {\n  intent = \"whatsapp\";\n}\nelse if (\n  text.includes(\"instagram\") ||\n  text.includes(\" ig \")\n) {\n  intent = \"instagram\";\n}\n\nreturn [{ intent, text }];\n\n"
      },
